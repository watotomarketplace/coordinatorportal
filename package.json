{
  "name": "watoto-celebration-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run build:watch\"",
    "client": "vite",
    "server": "node server/index.js",
    "build": "vite build",
    "build:watch": "vite build --watch --emptyOutDir false --mode development",
    "preview": "vite preview",
    "build:icons": "npx esbuild src/icons/icons-bundle.js --bundle --outfile=dist/assets/icons.js --format=iife --platform=browser"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.14",
    "@use-gesture/react": "^10.3.1",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "bullmq": "^5.73.4",
    "chart.js": "^4.4.1",
    "compression": "^1.8.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-session": "^1.18.0",
    "googleapis": "^131.0.0",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.10.1",
    "jspdf": "^2.5.1",
    "lucide-react": "^1.7.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.2",
    "pg": "^8.18.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-modal-sheet": "^5.6.0",
    "react-router-dom": "^6.22.0",
    "react-spring": "^10.0.3",
    "sql.js": "^1.10.0",
    "supertest": "^7.2.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "esbuild": "^0.28.0",
    "vite": "^5.1.0"
  }
}
